@echo off
chcp 65001 >nul
title 手机APP数据PC端连续展示工具

cls
echo ======================================================
echo             程序功能说明
echo ======================================================
echo 系统将手机APP数据在PC端连续性展示
echo 第一步：框选需要识别数据的屏幕区域
echo 第二步：自动采集并展示数据
echo ======================================================
echo.

:: ====================== 第一步：询问是否截屏 ======================
set /p "choice=是否开始截屏区域配置？[Y/N]："
if /i "%choice%"=="Y" (
    echo.
    echo 正在启动截屏区域选择工具...
    python select_area.py
    echo 截屏区域配置完成！
    echo.
) else (
    echo 已跳过截屏配置，将使用上次保存的区域...
    echo.
)

:: ====================== 第二步：询问是否开始观察数据 ======================
set /p "start=是否开始数据观察与展示？[Y/N]："
if /i "%start%"=="Y" (
    echo.
    echo 正在启动数据监控程序...
    echo 提示：按 Ctrl + C 可停止程序
    echo.
    python main.py
) else (
    echo 已取消数据观察，程序退出。
)

echo.
echo 程序已结束，按任意键关闭窗口...
pause >nul